<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ApiClient.ViewModels"
        x:Class="ApiClient.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        xmlns:models="using:ApiClient.Models"
        Title="ApiClient" Width="900" Height="650"
        x:Name="Root">

  <DockPanel Margin="12">

    <!-- Top bar: method + URL + send -->
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0 0 0 12">
      <ComboBox ItemsSource="{Binding Methods}" SelectedItem="{Binding Method}" Width="110"/>
      <TextBox Text="{Binding Url}" Watermark="https://api.example.com/endpoint"
               HorizontalAlignment="Stretch" Width="560"/>
      <Button Content="Send" Command="{Binding SendCommand}" IsEnabled="{Binding !IsBusy}"/>
    </StackPanel>

    <!-- Status bar -->
    <TextBlock DockPanel.Dock="Top" Text="{Binding StatusText}"
               Margin="0 0 0 8" FontSize="12" Foreground="Gray"/>

    <!-- Main split: request left, response right -->
    <Grid ColumnDefinitions="*,8,*">

      <!-- Request panel -->
      <TabControl Grid.Column="0">
        <TabItem Header="Headers">
          <DockPanel>
            <Button DockPanel.Dock="Bottom" Content="+ Add header"
                    Command="{Binding AddHeaderCommand}" Margin="0 6 0 0"/>
            <ScrollViewer>
              <ItemsControl ItemsSource="{Binding Headers}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="models:KeyValueItem">
                    <Grid ColumnDefinitions="32,*,8,*,32" Margin="0 3">
                      <CheckBox Grid.Column="0" IsChecked="{Binding Enabled}" VerticalAlignment="Center"/>
                      <TextBox Grid.Column="1" Text="{Binding Key}"   Watermark="Key"/>
                      <TextBox Grid.Column="3" Text="{Binding Value}" Watermark="Value"/>
                      <Button  Grid.Column="4" Content="×"
                               CommandParameter="{Binding}"
                               Command="{Binding #Root.((vm:MainWindowViewModel)DataContext).RemoveHeaderCommand}"/>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </DockPanel>
        </TabItem>
        <TabItem Header="Body">
          <TextBox Text="{Binding RequestBody}" AcceptsReturn="True"
                   FontFamily="Cascadia Code,Consolas,monospace" FontSize="13"
                   TextWrapping="Wrap" VerticalAlignment="Stretch"/>
        </TabItem>
      </TabControl>

      <GridSplitter Grid.Column="1" ResizeDirection="Columns"/>

      <!-- Response panel -->
      <TextBox Grid.Column="2" Text="{Binding ResponseBody}" IsReadOnly="True"
               AcceptsReturn="True" TextWrapping="Wrap"
               FontFamily="Cascadia Code,Consolas,monospace" FontSize="13"/>
    </Grid>
  </DockPanel>
</Window>